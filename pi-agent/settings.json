{
  "defaultProvider": "deepseek",
  "defaultModel": "deepseek-v4-flash",
  "defaultThinkingLevel": "xhigh",
  "hideThinkingBlock": false,
  "theme": "opencode",
  "collapseChangelog": true,
  "quietStartup": true,
  "enableInstallTelemetry": false,
  "lastChangelogVersion": "0.78.1",
  "packages": [
    "git:https://github.com/awtotty/pi-opencode.git",
    "npm:pi-mcp-adapter",
    "npm:pi-web-access",
    "npm:pi-subagents",
    "npm:pi-intercom",
    "git:github.com/MasuRii/pi-session-cleanup",
    "npm:pi-markdown-preview",
    "npm:pi-ask-user",
    "npm:pi-bar",
    "npm:@jerryan/pi-todo-lite",
    "npm:pi-memory"
  ],
  "bar": {
    "progressModel": "default"
  },
  "subagents": {
    "agentOverrides": {
      "scout": {
        "disabled": true
      },
      "worker": {
        "disabled": true
      },
      "reviewer": {
        "disabled": true
      },
      "planner": {
        "disabled": true
      }
    }
