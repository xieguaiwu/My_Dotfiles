{
  "defaultProvider": "opencode-go",
  "defaultModel": "deepseek-v4-flash",
  "defaultThinkingLevel": "xhigh",
  "hideThinkingBlock": false,
  "theme": "opencode",
  "collapseChangelog": true,
  "quietStartup": true,
  "enableInstallTelemetry": false,
  "lastChangelogVersion": "0.80.3",
  "packages": [
    "git:https://github.com/awtotty/pi-opencode.git",
    "npm:pi-mcp-adapter",
    "npm:pi-web-access",
    "npm:pi-subagents",
    "npm:pi-intercom",
    "git:https://github.com/MasuRii/pi-session-cleanup.git",
    "npm:pi-markdown-preview",
    "npm:pi-ask-user",
    "npm:pi-bar",
    "npm:@jerryan/pi-todo-lite",
    "npm:pi-memory",
    "npm:graphify-pi",
    "npm:pi-prompt-template-model"
  ],
  "bar": {
    "progressModel": "default"
  },
  "subagents": {
    "agentOverrides": {
      "scout": {
        "disabled": true
      },
      "worker": {
        "disabled": true
      },
      "reviewer": {
        "disabled": true
      },
      "planner": {
        "disabled": true
      },
      "explore": {
        "turnBudget": {
          "maxTurns": 15,
          "graceTurns": 3
        }
      },
      "deep": {
        "turnBudget": {
          "maxTurns": 25,
          "graceTurns": 5
        }
      }
    }
  }
}