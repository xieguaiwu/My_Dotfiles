{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".opencodeinstructions"
  ],
  "mode": {
    "build": {
      "prompt_append": "When user sends images, screenshots, or visual content, delegate to multimodal-looker agent for visual analysis."
    },
    "plan": {
      "prompt_append": "When user sends images, screenshots, or visual content, delegate to multimodal-looker agent for visual analysis."
    }
  },
  "permission": {
    "websearch": "allow",
    "webfetch": "allow"
  },
  "plugin": [
    "oh-my-openagent",
    "@tarquinen/opencode-dcp",
    "opencode-worktree",
    "opencode-pty",
    "opencode-browser",
    "opencode-wakatime",
    "opencode-websearch-cited"
  ],
  "disabled_providers": [
    "z-ai"
  ],
  "provider": {
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM",
      "models": {
        "z-ai/glm5": {
          "context": 128000,
          "reasoning": true
        },
        "moonshotai/kimi-k2.5": {
          "context": 128000,
          "attachment": true
        }
      },
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "shit"
      }
    }
  },
  "compaction": {
    "auto": true,
    "strategy": "summarize",
    "threshold": 0.6,
    "prune_tool_outputs": true
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    }
  }
}
