{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/main/assets/oh-my-opencode.schema.json",

  "agents": {
    // 编排/轻量 agent - opencode-go deepseek-v4-flash 主，直连 deepseek 备用
    "sisyphus": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": ["deepseek/deepseek-v4-flash"],
      "temperature": 0.4
    },
    "sisyphus-junior": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": ["deepseek/deepseek-v4-flash"],
      "temperature": 0.3
    },

    // 推理密集型 agent - opencode-go deepseek-v4-pro 主，直连 deepseek 备用
    "prometheus": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": ["deepseek/deepseek-v4-pro"],
      "temperature": 0.3
    },
    "oracle": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": ["deepseek/deepseek-v4-pro"],
      "temperature": 0.2
    },
    "metis": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": ["deepseek/deepseek-v4-pro"],
      "temperature": 0.3
    },
    "hephaestus": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": ["deepseek/deepseek-v4-pro"],
      "temperature": 0.3
    },
    "momus": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": ["deepseek/deepseek-v4-pro"],
      "temperature": 0.2
    },

    // === 需要大上下文/速度的 agent - 使用 big-pickle ===

    // Explore - 快速代码搜索，速度优先
    "explore": {
      "model": "opencode/big-pickle",
      "fallback_models": ["opencode-go/deepseek-v4-flash"],
      "temperature": 0.1
    },

    // Librarian - 文档搜索，需要大上下文
    "librarian": {
      "model": "opencode/big-pickle",
      "fallback_models": ["opencode-go/deepseek-v4-flash"],
      "temperature": 0.1
    },

    // === 需要视觉能力的 agent - Maverick 主（稳定可靠），Qwen3.5-397B 备用（视觉更强但免费 API 过载频繁）===

    // 多模态视觉分析 - 专职处理图像、截图、图表等视觉内容
    // Llama 4 Maverick 主模型：1M 上下文，稳定可靠，免费 tier 拥塞少
    // Qwen3.5-397B fallback：视觉推理更强 (MMMU 85.0) 但免费 API 经常 DEGRADED/超时，备用
    "multimodal-looker": {
      "model": "nvidia/meta/llama-4-maverick-17b-128e-instruct",
      "fallback_models": ["nvidia/qwen/qwen3.5-397b-a17b", "nvidia/moonshotai/kimi-k2.5"],
      "temperature": 0.3,
      "prompt_append": "When analyzing images: 1) Describe all visible elements (UI components, text, colors, layout). 2) Identify any issues or anomalies. 3) For UI screenshots, check design consistency and usability. 4) Provide structured, detailed analysis."
    },

    // 前端测试 - 需要分析界面截图、UI渲染结果+生成测试代码
    // Maverick 主模型：1M 上下文稳定可靠；Qwen3.5 视觉更强但免费 API 过载频繁，做 fallback
    "frontend-tester": {
      "model": "nvidia/meta/llama-4-maverick-17b-128e-instruct",
      "fallback_models": ["nvidia/qwen/qwen3.5-397b-a17b"],
      "temperature": 0.3
    },

    // 信息收集 - 需要处理图像、图表、截图等视觉信息
    // Maverick 主模型：稳定可靠，1M 上下文；Qwen3.5 视觉更强但免费 API 过载频繁，做 fallback
    "information-collector": {
      "model": "nvidia/meta/llama-4-maverick-17b-128e-instruct",
      "fallback_models": ["nvidia/qwen/qwen3.5-397b-a17b"],
      "temperature": 0.2
    },

  },

  // 分类任务 - OpenCode Go 主力，直连 DeepSeek 备用
  "categories": {
    // 轻量任务
    "quick": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": ["deepseek/deepseek-v4-flash"],
      "temperature": 0.2
    },
    "unspecified-low": {
      "model": "opencode/big-pickle",
      "fallback_models": ["deepseek/deepseek-v4-flash"],
      "temperature": 0.2
    },

    // 中高强度任务
    "unspecified-high": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": ["deepseek/deepseek-v4-flash"],
      "temperature": 0.3
    },
    "writing": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": ["deepseek/deepseek-v4-flash"],
      "temperature": 0.5
    },
    "technical-writing": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": ["deepseek/deepseek-v4-flash"],
      "temperature": 0.3
    },

    // 视觉工程 - 需要视觉能力
    "visual-engineering": {
      "model": "nvidia/meta/llama-4-maverick-17b-128e-instruct",
      "fallback_models": ["nvidia/moonshotai/kimi-k2-instruct"],
      "temperature": 0.4
    },

    // 超脑 - 最强推理
    "ultrabrain": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": ["deepseek/deepseek-v4-pro"],
      "temperature": 0.2
    },

    // 深度 - 自主研究+实现
    "deep": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": ["deepseek/deepseek-v4-pro"],
      "temperature": 0.3
    },

    // 艺术性 - 创造性/非传统方法
    "artistry": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": ["deepseek/deepseek-v4-flash"],
      "temperature": 0.7
    }
  }
}
